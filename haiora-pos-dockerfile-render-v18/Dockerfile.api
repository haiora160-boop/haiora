FROM node:20-alpine

WORKDIR /app

COPY apps/api/package*.json ./

RUN npm install --legacy-peer-deps \
  && npm install prisma@6.19.0 @prisma/client@6.19.0 tsx@4.20.5 --save-exact --legacy-peer-deps

COPY apps/api/prisma ./prisma
COPY apps/api/src ./src
COPY apps/api/tsconfig.json ./tsconfig.json

RUN npx prisma@6.19.0 generate

EXPOSE 4000

CMD ["sh", "-c", "npx prisma@6.19.0 db push && npx tsx prisma/seed.ts && npx tsx src/index.ts"]
