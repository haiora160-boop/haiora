# ROOT ENV FOR DOCKER COMPOSE
NODE_ENV=development

# WEB
NEXT_PUBLIC_API_URL=auto
NEXT_PUBLIC_SOCKET_URL=auto

# API
PORT=4000
WEB_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
JWT_SECRET=change_this_super_secret_key
JWT_EXPIRES_IN=7d

# DATABASE - local docker
DATABASE_URL=postgresql://pos_user:pos_password@postgres:5432/pos_saas_db?schema=public

# REDIS - optional, local docker only
REDIS_URL=redis://redis:6379

# SUPER ADMIN seed account
SUPER_ADMIN_EMAIL=admin@possaas.vn
SUPER_ADMIN_PASSWORD=Admin@123456

# Optional: public URL for uploaded images, e.g. https://api.yourdomain.com
PUBLIC_UPLOAD_BASE_URL=
API_PUBLIC_URL=
